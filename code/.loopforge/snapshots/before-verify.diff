-if [[ -z "$SOURCE_ROOT" ]]; then
-  if [[ "$(uname -s 2>/dev/null)" == "Linux" && -d "/__CONTEST_PLATFORM_SOURCE_ROOT__/FlashDB" ]]; then
-    SOURCE_ROOT="/__CONTEST_PLATFORM_SOURCE_ROOT__/FlashDB"
